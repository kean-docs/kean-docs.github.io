{"hierarchy":{"paths":[["doc:\/\/com.github.kean.nuke\/documentation\/Nuke","doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/caching"]]},"metadata":{"modules":[{"name":"Nuke"}],"roleHeading":"Article","role":"article","title":"Cache Layers"},"abstract":[{"type":"text","text":"Learn about memory and disk cache layers in Nuke."}],"sections":[],"variants":[{"paths":["\/documentation\/nuke\/cache-layers"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Nuke has three cache layers:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImageCache","isActive":true,"type":"reference"},{"text":" – LRU ","type":"text"},{"type":"strong","inlineContent":[{"text":"memory","type":"text"}]},{"text":" cache for processed images","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataCache","isActive":true,"type":"reference"},{"text":" – aggressive LRU ","type":"text"},{"type":"strong","inlineContent":[{"text":"disk","type":"text"}]},{"text":" cache","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/urlcache","isActive":true,"type":"reference"},{"text":" – HTTP ","type":"text"},{"type":"strong","inlineContent":[{"text":"disk","type":"text"}]},{"text":" cache, which is part of the native ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/url_loading_system","isActive":true,"type":"reference"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default pipeline uses a combination of "},{"isActive":true,"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImageCache","type":"reference"},{"type":"text","text":" and "},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/urlcache","type":"reference","overridingTitleInlineContent":[{"code":"URLCache","type":"codeVoice"}],"overridingTitle":"URLCache"},{"type":"text","text":" with an increased disk size. This configuration supports HTTP "},{"isActive":true,"identifier":"https:\/\/developer.mozilla.org\/en-US\/docs\/Web\/HTTP\/Headers\/Cache-Control","type":"reference"},{"type":"text","text":"."}]},{"level":3,"anchor":"Memory-Cache","type":"heading","text":"Memory Cache"},{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImageCache","type":"reference"},{"type":"text","text":" is a "},{"type":"strong","inlineContent":[{"type":"text","text":"memory"}]},{"type":"text","text":" cache with an "},{"isActive":true,"identifier":"https:\/\/en.wikipedia.org\/wiki\/Cache_replacement_policies#Least_recently_used_(LRU)","type":"reference"},{"type":"text","text":" policy (least recently used are removed first). The pipeline uses it to store processed images that are decompressed and ready to be displayed."}]},{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImageCache","type":"reference"},{"type":"text","text":" discards the least recently cached images if either "},{"type":"emphasis","inlineContent":[{"type":"text","text":"cost"}]},{"type":"text","text":" or "},{"type":"emphasis","inlineContent":[{"type":"text","text":"count"}]},{"type":"text","text":" limit is reached. The default cost limit represents a number of bytes and is calculated based on the amount of physical memory available on the device. The default count limit is "},{"type":"codeVoice","code":"Int.max"},{"type":"text","text":"."}]},{"syntax":"swift","code":["\/\/ Configure cache","ImageCache.shared.costLimit = 1024 * 1024 * 100 \/\/ 100 MB","ImageCache.shared.countLimit = 100","ImageCache.shared.ttl = 120 \/\/ Invalidate image after 120 sec","","\/\/ Read and write images","let request = ImageRequest(url: url)","ImageCache.shared[request] = ImageContainer(image: image)","let image = ImageCache.shared[request]","","\/\/ Clear cache","ImageCache.shared.removeAll()"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ImageCache"},{"type":"text","text":" automatically removes all stored elements when it receives a memory warning. It also automatically removes "},{"type":"emphasis","inlineContent":[{"type":"text","text":"most"}]},{"type":"text","text":" stored elements when the app enters the background."}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can implement a custom cache by conforming to the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImageCaching"},{"text":" protocol.","type":"text"}]}],"name":"Note","type":"aside","style":"note"},{"level":3,"anchor":"HTTP-Disk-Cache","type":"heading","text":"HTTP Disk Cache"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","overridingTitleInlineContent":[{"type":"codeVoice","code":"URLCache"}],"overridingTitle":"URLCache","identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/urlcache"},{"type":"text","text":" is an HTTP "},{"type":"strong","inlineContent":[{"type":"text","text":"disk"}]},{"type":"text","text":" cache that is part of the native "},{"isActive":true,"type":"reference","overridingTitleInlineContent":[{"type":"text","text":"URL loading system"}],"overridingTitle":"URL loading system","identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/url_loading_system"},{"text":". It is used by the default image pipeline, which is instantiated with a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImagePipeline\/Configuration-swift.struct\/withURLCache"},{"text":" configuration.","type":"text"}]},{"syntax":"swift","code":["\/\/ Configure cache","DataLoader.sharedUrlCache.diskCapacity = 100","DataLoader.sharedUrlCache.memoryCapacity = 0","","\/\/ Read and write responses","let urlRequest = URLRequest(url: url)","_ = DataLoader.sharedUrlCache.cachedResponse(for: urlRequest)","DataLoader.sharedUrlCache.removeCachedResponse(for: urlRequest)","","\/\/ Clear cache","DataLoader.sharedUrlCache.removeAllCachedResponses()"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"An HTTP disk cache (","type":"text"},{"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImagePipeline\/Configuration-swift.struct\/withURLCache","isActive":true,"type":"reference"},{"type":"text","text":" option) gives the server precise control over caching via "},{"identifier":"https:\/\/developer.mozilla.org\/en-US\/docs\/Web\/HTTP\/Headers\/Cache-Control","isActive":true,"type":"reference","overridingTitleInlineContent":[{"type":"codeVoice","code":"cache-control"}],"overridingTitle":"cache-control"},{"type":"text","text":" HTTP headers. You can specify what images to cache and for how long. The client can also periodically check the cached response for "},{"identifier":"https:\/\/developer.mozilla.org\/en-US\/docs\/Web\/HTTP\/Caching#freshness","isActive":true,"type":"reference"},{"type":"text","text":" and refresh if needed – useful for refreshing profile pictures or logos."}]},{"content":[{"inlineContent":[{"text":"Learn more about HTTP cache in ","type":"text"},{"type":"reference","identifier":"https:\/\/kean.blog\/post\/image-caching#http-caching","isActive":true}],"type":"paragraph"}],"name":"Tip","type":"aside","style":"tip"},{"type":"heading","level":4,"text":"Serving Stale Images","anchor":"Serving-Stale-Images"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the resource expires, "},{"code":"URLSession","type":"codeVoice"},{"type":"text","text":" isn’t going to serve it until it goes to the server and validates whether the contents stored in the cache are still fresh."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Solutions"}]}]},{"items":[{"content":[{"inlineContent":[{"text":"Increase the expiration age in HTTP ","type":"text"},{"type":"codeVoice","code":"cache-control"},{"type":"text","text":" headers"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Use a custom disk cache that ignores HTTP ","type":"text"},{"code":"cache-control","type":"codeVoice"},{"type":"text","text":" headers"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Ask "},{"code":"URLSession","type":"codeVoice"},{"type":"text","text":" to return an expired image using "},{"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/nsurlrequest\/cachepolicy\/returncachedatadontload","isActive":true,"type":"reference"},{"type":"text","text":" and then validate it later in the background"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dynamically switch between "},{"code":".useProtocolCachePolicy","type":"codeVoice"},{"type":"text","text":" to "},{"code":".returnCacheDataDontLoad","type":"codeVoice"},{"type":"text","text":" when network appears to be offline"}]}]}],"type":"unorderedList"},{"type":"heading","level":3,"text":"Aggressive Disk Cache","anchor":"Aggressive-Disk-Cache"},{"inlineContent":[{"type":"text","text":"If HTTP caching is not your cup of tea, try a custom LRU disk cache for fast and reliable "},{"type":"emphasis","inlineContent":[{"type":"text","text":"aggressive"}]},{"type":"text","text":" data caching (ignores "},{"overridingTitleInlineContent":[{"text":"HTTP cache control","type":"text"}],"overridingTitle":"HTTP cache control","type":"reference","identifier":"https:\/\/developer.mozilla.org\/en-US\/docs\/Web\/HTTP\/Headers\/Cache-Control","isActive":true},{"type":"text","text":"). You can enable it using the respective pipeline configuration."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["ImagePipeline.shared = ImagePipeline(configuration: .withDataCache)"]},{"inlineContent":[{"type":"text","text":"If you want to change the disk cache configuration, you can also instantiate "},{"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataCache","isActive":true},{"type":"text","text":" manually or even provide your own implementation by conforming to "},{"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataCaching","isActive":true},{"type":"text","text":" protocol:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["ImagePipeline {","    $0.dataCache = try? DataCache(name: \"com.myapp.datacache\")","}"]},{"content":[{"type":"paragraph","inlineContent":[{"text":"If you enable it manually, make sure to disable the native URL cache. To do it, pass a ","type":"text"},{"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataLoader","isActive":true,"type":"reference"},{"type":"text","text":" with a custom "},{"type":"codeVoice","code":"URLSessionConfiguration"},{"type":"text","text":" when creating a pipeline. Built-in "},{"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImagePipeline\/Configuration-swift.struct\/withDataCache","isActive":true,"type":"reference"},{"type":"text","text":" configuration takes care of it automatically for you."}]}],"type":"aside","style":"important","name":"Important"},{"inlineContent":[{"type":"text","text":"By default, the pipeline stores only the original image data. You can change this behavior by specifying a different cache policy that was "},{"isActive":true,"identifier":"#cache-policy","type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let dataCache = try DataCache(name: \"my-cache\")","","dataCache.sizeLimit = 1024 * 1024 * 100 \/\/ 100 MB","","dataCache.storeData(data, for: \"key\")","if dataCache.containsData(for: \"key\") {","    print(\"Data is cached\")","}","let data = dataCache.cachedData(for: \"key\")","\/\/ or let data = dataCache[\"key\"]","dataCache.removeData(for: \"key\")","dataCache.removeAll()"]},{"inlineContent":[{"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataCache","isActive":true,"type":"reference"},{"text":" is asynchronous which means ","type":"text"},{"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataCache\/storeData(_:for:)","isActive":true,"type":"reference"},{"type":"text","text":" method returns immediately and the disk I\/O happens later. For a synchronous write, use "},{"isActive":true,"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataCache\/flush()","type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"style":"tip","type":"aside","content":[{"inlineContent":[{"type":"text","text":"To share a disk cache between your app and an extension (e.g. a Notification Service Extension), point "},{"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataCache","isActive":true,"type":"reference"},{"type":"text","text":" at a directory inside a shared app group container. Set "},{"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataCache\/isSweepEnabled","isActive":true,"type":"reference"},{"type":"text","text":" to "},{"type":"codeVoice","code":"false"},{"type":"text","text":" in the extension so that only the main app enforces size limits."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let sharedCacheURL = FileManager.default","    .containerURL(forSecurityApplicationGroupIdentifier: \"group.com.myapp\")","","\/\/ Main app","ImagePipeline.shared = ImagePipeline {","    $0.dataCache = try? DataCache(path: sharedCacheURL)","}","","\/\/ Extension — reads\/writes the same cache but skips LRU sweeps","ImagePipel