{"hierarchy":{"paths":[["doc:\/\/com.github.kean.nuke\/documentation\/Nuke"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/nuke\/loading-data"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/loading-data"},"abstract":[{"type":"text","text":"Learn how pipeline loads data."}],"topicSections":[{"identifiers":["doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataLoading","doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataLoader"],"anchor":"Data-Loader","title":"Data Loader"}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataLoader"},{"type":"text","text":" uses "},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/reference\/foundation\/nsurlsession"},{"type":"text","text":" to load image data. The data is cached on disk using "},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/reference\/foundation\/urlcache"},{"type":"text","text":", which by default is initialized with a memory capacity of 0 MB (Nuke only stores processed images in memory) and a disk capacity of 150 MB."}]},{"type":"aside","style":"tip","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/kean.blog\/post\/image-caching"},{"text":" to learn more about HTTP cache. To learn more about caching in Nuke and how to configure it, see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/caching"},{"text":".","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"URLSession"},{"type":"text","text":" class natively supports the following URL schemes: "},{"type":"codeVoice","code":"data"},{"type":"text","text":", "},{"type":"codeVoice","code":"file"},{"type":"text","text":", "},{"type":"codeVoice","code":"ftp"},{"type":"text","text":", "},{"type":"codeVoice","code":"http"},{"type":"text","text":", and "},{"type":"codeVoice","code":"https"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataLoader"},{"type":"text","text":" works great for most situations, but if you need to provide a custom networking layer, you can use a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataLoading"},{"type":"text","text":" protocol. See also, "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/kean\/Nuke-Alamofire-Plugin"},{"type":"text","text":"."}]},{"type":"heading","level":2,"text":"Intercepting Requests","anchor":"Intercepting-Requests"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To modify a URL request just before it is sent — for example, to inject authentication tokens or sign requests — implement "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImagePipeline\/Delegate\/willLoadData(for:urlRequest:pipeline:)"},{"type":"text","text":" in your pipeline delegate:"}]},{"type":"codeListing","syntax":"swift","code":["final class AuthenticatedPipelineDelegate: ImagePipeline.Delegate {","    func willLoadData(","        for request: ImageRequest,","        urlRequest: URLRequest,","        pipeline: ImagePipeline","    ) async throws -> URLRequest {","        var urlRequest = urlRequest","        let token = try await TokenStore.shared.validToken() \/\/ async, throws on failure","        urlRequest.setValue(\"Bearer \\(token)\", forHTTPHeaderField: \"Authorization\")","        return urlRequest","    }","}","","let pipeline = ImagePipeline(delegate: AuthenticatedPipelineDelegate()) {","    \/\/ ...","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The method is called on every URL-based request, after resumable data headers are applied but before the request is passed to "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataLoading"},{"type":"text","text":". Throwing an error cancels the request and surfaces the error as "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImagePipeline\/Error\/dataLoadingFailed(error:)"},{"type":"text","text":". The hook is not called for requests that use a custom data fetch closure or that target local file resources."}]},{"type":"heading","level":2,"text":"Monitoring Network Requests","anchor":"Monitoring-Network-Requests"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Nuke can be used with "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/kean\/Pulse"},{"type":"text","text":" for monitoring network traffic."}]},{"type":"codeListing","syntax":"swift","code":["(ImagePipeline.shared.configuration.dataLoader as? DataLoader)?.delegate = URLSessionProxyDelegate()"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The same "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataLoader\/delegate"},{"type":"text","text":" can be used for modifying data loader behavior, e.g. for handling authentication requests and other aspects of data loading."}]},{"type":"codeListing","syntax":"swift","code":["\/\/ The delegate is retained by the `DataLoader`.","(ImagePipeline.shared.configuration.dataLoader as? DataLoader)?.delegate = YourDelegate()","","final class YourDelegate: URLSessionTaskDelegate {","    func urlSession(_ session: URLSession, task: URLSessionTask, didReceive challenge: URLAuthenticationChallenge, completionHandler: @escaping (URLSession.AuthChallengeDisposition, URLCredential?) -> Void) {","        \/\/ Handle authentication challenge...","    }","}"]},{"type":"heading","level":2,"text":"Resumable Downloads","anchor":"Resumable-Downloads"},{"inlineContent":[{"text":"If the data task is terminated when the image is partially loaded (either because of a failure or a cancellation), the next load will resume where the previous one left off. Resumable downloads require the server to support ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.mozilla.org\/en-US\/docs\/Web\/HTTP\/Range_requests"},{"text":". Nuke supports both validators: ","type":"text"},{"code":"ETag","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"Last-Modified"},{"text":". Resumable downloads are enabled by default. You can learn more in ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/kean.blog\/post\/resumable-downloads"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Custom-Networking-Layer","text":"Custom Networking Layer","type":"heading"},{"inlineContent":[{"text":"If you’d like to use some other networking library or custom code, implement the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataLoading"},{"text":" protocol.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"The-DataLoading-Protocol-Contract","text":"The DataLoading Protocol Contract","type":"heading"},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataLoading"},{"text":" has a single method:","type":"text"}],"type":"paragraph"},{"code":["func loadData(","    with request: URLRequest,","    didReceiveData: @escaping @Sendable (Data, URLResponse) -> Void,","    completion: @escaping @Sendable (Error?) -> Void",") -> any Cancellable"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Threading:","type":"text"}]},{"text":" ","type":"text"},{"type":"codeVoice","code":"didReceiveData"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"completion"},{"text":" can be called on any thread.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Incremental delivery:","type":"text"}]},{"text":" Call ","type":"text"},{"type":"codeVoice","code":"didReceiveData"},{"text":" each time a new chunk arrives. Nuke uses these chunks for progressive decoding. Each call must include a ","type":"text"},{"type":"codeVoice","code":"URLResponse"},{"text":" — pass the response you received from the first chunk onward.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Completion:","type":"text"}]},{"text":" Call ","type":"text"},{"type":"codeVoice","code":"completion"},{"text":" exactly once when the load finishes. Pass ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" on success, or an ","type":"text"},{"type":"codeVoice","code":"Error"},{"text":" on failure. Do not call ","type":"text"},{"type":"codeVoice","code":"didReceiveData"},{"text":" after calling ","type":"text"},{"type":"codeVoice","code":"completion"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Cancellation:","type":"text"}]},{"text":" Return a ","type":"text"},{"type":"codeVoice","code":"Cancellable"},{"text":" whose ","type":"text"},{"type":"codeVoice","code":"cancel()"},{"text":" method stops the underlying task and ensures neither ","type":"text"},{"type":"codeVoice","code":"didReceiveData"},{"text":" nor ","type":"text"},{"type":"codeVoice","code":"completion"},{"text":" are called after cancellation.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Alamofire-Example","text":"Alamofire Example","type":"heading"},{"inlineContent":[{"text":"An ","type":"text"},{"type":"reference","overridingTitle":"Alamofire plugin","overridingTitleInlineContent":[{"text":"Alamofire plugin","type":"text"}],"isActive":true,"identifier":"https:\/\/github.com\/kean\/Nuke-Alamofire-Plugin"},{"text":" is available, but here is how a minimal implementation looks to illustrate the protocol contract:","type":"text"}],"type":"paragraph"},{"code":["\/\/\/ Implements data loading using Alamofire framework.","public class AlamofireDataLoader: Nuke.DataLoading {","    public let session: Alamofire.Session","","    \/\/\/ Initializes the receiver with a given Alamofire.SessionManager.","    \/\/\/ - parameter session: Alamofire.Session.default by default.","    public init(session: Alamofire.Session = Alamofire.Session.default) {","        self.session = session","    }","","    \/\/ MARK: DataLoading","","    \/\/\/ Loads data using Alamofire.SessionManager.","    public func loadData(","        with request: URLRequest,","        didReceiveData: @escaping @Sendable (Data, URLResponse) -> Void,","        completion: @escaping @Sendable (Error?) -> Void","    ) -> any Cancellable {","        let task = self.session.streamRequest(request)","        task.responseStream { [weak task] stream in","            switch stream.event {","            case let .stream(result):","                switch result {","                case let .success(data):","                    if let response = task?.response {","                        didReceiveData(data, response)","                    }","                }","            case let .complete(response):","                completion(response.error)","            }","        }","        .resume()","        return task","    }","}","","extension Alamofire.Request: Nuke.Cancellable {}"],"type":"codeListing","syntax":"swift"}]}],"metadata":{"modules":[{"name":"Nuke"}],"role":"collectionGroup","title":"Loading Data","roleHeading":"API Collection"},"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/image-processing","doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/image-formats","doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImagePipeline\/Delegate"],"anchor":"Customization","title":"Customization"}],"kind":"article","sections":[],"references":{"doc://com.github.kean.nuke/documentation/Nuke/DataLoading":{"type":"topic","role":"symbol","kind":"symbol","title":"DataLoading","navigatorTitle":[{"text":"DataLoading","kind":"identifier"}],"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"DataLoading","kind":"identifier"}],"url":"\/documentation\/nuke\/dataloading","abstract":[{"type":"text","text":"Fetches original image data."}],"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataLoading"},"doc://com.github.kean.nuke/documentation/Nuke/ImagePipeline/Delegate/willLoadData(for:urlRequest:pipeline:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"willLoadData"},{"kind":"text","text":"("},{"kind":"externalParam","text":"for"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4Nuke12ImageRequestV","text":"ImageRequest","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"urlRequest"},{"text":": ","kind":"text"},{"text":"URLRequest","kind":"typeIdentifier","preciseIdentifier":"s:10Foundation10URLRequestV"},{"kind":"text","text":", "},{"kind":"externalParam","text":"pipeline"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ImagePipeline","preciseIdentifier":"s:4Nuke13ImagePipelineC"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:10Foundation10URLRequestV","text":"URLRequest","kind":"typeIdentifier"}],"defaultImplementations":1,"abstract":[{"text":"Intercepts the URL request just before data loading begins, allowing","type":"text"},{"text":" ","type":"text"},{"text":"you to modify or replace it.","type":"text"}],"kind":"symbol","required":true,"type":"topic","url":"\/documentation\/nuke\/imagepipeline\/delegate\/willloaddata(for:urlrequest:pipeline:)","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImagePipeline\/Delegate\/willLoadData(for:urlRequest:pipeline:)","title":"willLoadData(for:urlRequest:pipeline:)","role":"symbol"},"doc://com.github.kean.nuke/documentation/Nuke/DataLoader/delegate":{"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/DataLoader\/delegate","abstract":[{"type":"text","text":"The delegate that gets called for the callbacks handled by the data loader."},{"type":"text","text":" "},{"type":"text","text":"You can use it for observing the session events and modifying some of the"},{"type":"text","text":" "},{"type":"text","text":"task behavior, e.g. handling authentication challenges."}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"delegate","kind":"identifier"},{"text":": ","kind":"text"},{"text":"URLSessionDelegate","kind":"typeIdentifier","preciseIdentifier":"c:objc(pl)NSURLSessionDelegate"},{"text":"?","kind":"text"}],"title":"delegate","role":"symbol","type":"topic","url":"\/documentation\/nuke\/dataloader\/delegate","kind":"symbol"},"doc://com.github.kean.nuke/documentation/Nuke/image-formats":{"type":"topic","abstract":[{"type":"text","text":"Learn about image formats supported in Nuke and how to extend them."}],"kind":"article","url":"\/documentation\/nuke\/image-formats","title":"Image Formats","role":"collectionGroup","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/image-formats"},"doc://com.github.kean.nuke/documentation/Nuke":{"url":"\/documentation\/nuke","kind":"symbol","role":"collection","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke","abstract":[{"type":"text","text":"A powerful image loading system for Apple platforms."}],"title":"N