{"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/nuke\/supported-image-formats"]}],"identifier":{"url":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/supported-image-formats","interfaceLanguage":"swift"},"abstract":[{"text":"Nuke has built-in support for basic image formats like ","type":"text"},{"code":"jpeg","type":"codeVoice"},{"text":", ","type":"text"},{"code":"png","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"heif","type":"codeVoice"},{"text":". It also has the infrastructure for supporting a variety of custom image formats.","type":"text"}],"primaryContentSections":[{"content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Nuke is capable of driving progressive decoding, animated image rendering, progressive animated image rendering, drawing vector images directly or converting them to bitmaps, parsing thumbnails included in the image containers, and more."}],"type":"paragraph"},{"text":"Common Image Formats","anchor":"Common-Image-Formats","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"All image formats natively supported by the platform are also supported by Nuke, including "},{"type":"codeVoice","code":"PNG"},{"type":"text","text":", "},{"type":"codeVoice","code":"TIFF"},{"type":"text","text":", "},{"type":"codeVoice","code":"JPEG"},{"type":"text","text":", "},{"type":"codeVoice","code":"GIF"},{"type":"text","text":", "},{"type":"codeVoice","code":"BMP"},{"type":"text","text":", "},{"type":"codeVoice","code":"ICO"},{"type":"text","text":", "},{"type":"codeVoice","code":"CUR"},{"type":"text","text":", "},{"type":"codeVoice","code":"XBM"},{"type":"text","text":", "},{"type":"codeVoice","code":"HEIF"},{"type":"text","text":", and "},{"type":"codeVoice","code":"WebP"},{"type":"text","text":" (iOS 14+)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can use the basic "},{"type":"codeVoice","code":"UIImageView"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"NSImageView"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"WKInterfaceImage"},{"type":"text","text":" to render the images of any of the natively supported formats."}],"type":"paragraph"},{"text":"Progressive JPEG","anchor":"Progressive-JPEG","type":"heading","level":3},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Decoding","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImageDecoders\/Default"},{"type":"text","text":" supports progressive JPEG via "},{"type":"codeVoice","code":"CGImageSourceCreateIncremental"},{"type":"text","text":". When "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImagePipeline\/Configuration-swift.struct\/isProgressiveDecodingEnabled"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"type":"text","text":", the pipeline produces previews as data arrives."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"By default, progressive previews are only enabled for progressive JPEGs and GIFs ("},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImagePipeline\/PreviewPolicy"},{"type":"text","text":"). Baseline JPEGs, PNGs, and other formats produce no previews unless explicitly configured via "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImagePipeline\/Delegate\/previewPolicy(for:pipeline:)"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For progressive JPEGs with large EXIF headers where "},{"type":"codeVoice","code":"CGImageSourceCreateIncremental"},{"type":"text","text":" fails to produce incremental previews, the decoder automatically falls back to generating a thumbnail from the available data."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Encoding","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"None."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Rendering","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To render progressive JPEG, you can use the basic "},{"type":"codeVoice","code":"UIImageView"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"NSImageView"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"WKInterfaceImage"},{"type":"text","text":". The default image view loading extensions also support displaying progressive previews."}],"type":"paragraph"},{"text":"HEIF","anchor":"HEIF","type":"heading","level":3},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Decoding","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImageDecoders\/Default"},{"text":" supports ","type":"text"},{"isActive":true,"identifier":"https:\/\/en.wikipedia.org\/wiki\/High_Efficiency_Image_File_Format","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Encoding","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImageEncoders\/Default","isActive":true},{"text":" supports ","type":"text"},{"overridingTitleInlineContent":[{"type":"text","text":"HEIF"}],"type":"reference","isActive":true,"overridingTitle":"HEIF","identifier":"https:\/\/en.wikipedia.org\/wiki\/High_Efficiency_Image_File_Format"},{"text":" but doesn’t use it by default. To enable it, use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImageEncoders\/Default\/isHEIFPreferred"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"You can use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImageEncoders\/ImageIO"},{"text":" directly:","type":"text"}]},{"code":["let image: UIImage","let encoder = ImageEncoders.ImageIO(type: .heif, compressionRatio: 0.8)","let data = encoder.encode(image: image)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Rendering"}]}]},{"type":"paragraph","inlineContent":[{"text":"To render HEIF images, you can use ","type":"text"},{"type":"codeVoice","code":"UIImageView"},{"text":"\/","type":"text"},{"type":"codeVoice","code":"NSImageView"},{"text":"\/","type":"text"},{"type":"codeVoice","code":"WKInterfaceImage"},{"type":"text","text":"."}]},{"anchor":"GIF","text":"GIF","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Decoding","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImageDecoders\/Default","isActive":true},{"type":"text","text":" automatically recognizes GIFs. It creates an image container ("},{"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImageContainer","isActive":true},{"type":"text","text":") with the first frame of the GIF as a placeholder and attaches the original image data to the container so that you can perform just-in-time decoding at rendering time."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Encoding"}]}]},{"type":"paragraph","inlineContent":[{"text":"None.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Rendering"}]}]},{"type":"paragraph","inlineContent":[{"text":"To render animated GIFs, please consider using one of the open-source GIF rendering engines, like ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/kaishin\/Gifu","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/Flipboard\/FLAnimatedImage","type":"reference"},{"text":", or other.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Gifu Example"}]}]},{"code":["\/\/\/ A custom image view that supports downloading and displaying animated images.","final class ImageView: UIView {","    private let imageView: GIFImageView","    private let spinner: UIActivityIndicatorView","    private var task: ImageTask?","","    \/* Initializers skipped *\/","","    func setImage(with url: URL) {","        prepareForReuse()","","        if let response = ImagePipeline.shared.cache[url] {","            imageView.display(response: response)","            if !response.isPreview {","                return ","            }","        }","","        spinner.startAnimating()","        task = ImagePipeline.shared.loadImage(with: url) { [weak self] result in","            self?.spinner.stopAnimating()","            if case let .success(response) = result {","                self?.imageView.display(response: response)","            }","        }","    }","    ","    private func display(response: ImageResponse) {","        if let data = response.container.data {","            animate(withGIFData: data)","        } else {","            image = response.image","        }","    }","    ","    private func prepareForReuse() {","        task?.cancel()","        spinner.stopAnimating()","        imageView.prepareForReuse()","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"To see this code in action, check out the ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/kean\/NukeDemo","type":"reference"},{"text":".","type":"text"}]},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"GIF"},{"type":"text","text":" is not the most efficient format for transferring and displaying animated images. Consider using "},{"type":"reference","identifier":"https:\/\/developers.google.com\/web\/fundamentals\/performance\/optimizing-content-efficiency\/replace-animated-gifs-with-video\/","isActive":true},{"type":"text","text":". You can find a PoC available in the "},{"type":"reference","overridingTitle":"demo project","identifier":"https:\/\/github.com\/kean\/NukeDemo","isActive":true,"overridingTitleInlineContent":[{"text":"demo project","type":"text"}]},{"type":"text","text":" that uses Nuke to load, cache and display an "},{"type":"codeVoice","code":"MP4"},{"type":"text","text":" video."}]}]},{"level":3,"type":"heading","text":"SVG","anchor":"SVG"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Decoding"}]}]},{"type":"paragraph","inlineContent":[{"text":"There is currently no built-in support for SVG. Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImageDecoders\/Empty","type":"reference"},{"text":" to pass the original image data to an SVG-enabled view and render it using an external mechanism.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Encoding"}]}]},{"type":"paragraph","inlineContent":[{"text":"None.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Rendering"}]}]},{"type":"paragraph","inlineContent":[{"text":"To render SVG, consider using ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/mchoe\/SwiftSVG","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/SVGKit\/SVGKit","type":"reference"},{"text":", or other frameworks. Here is an example of ","type":"text"},{"code":"SwiftSVG","type":"codeVoice"},{"text":" rendering vector images.","type":"text"}]},{"code":["ImageDecoderRegistry.shared.register { context in","    \/\/ Replace this with whatever works for you. There are no magic numbers","    \/\/ for SVG like are used for other binary formats, it's just XML.","    let isSVG = context.urlResponse?.url?.absoluteString.hasSuffix(\".svg\") ?? false","    return isSVG ? ImageDecoders.Empty() : nil","}","","let url = URL(string: \"https:\/\/upload.wikimedia.org\/wikipedia\/commons\/9\/9d\/Swift_logo.svg\")","ImagePipeline.shared.loadImage(with: url) { [weak self] result in","    guard let self, let data = try? result.get().container.data else {","        return","    }","    \/\/ You can render an image using whatever size you want, vector!","    let targetBounds = CGRect(origin: .zero, size: CGSize(width: 300, height: 300))","    let svgView = UIView(SVGData: data) { layer in","        layer.fillColor = UIColor.orange.cgColor","        layer.resizeToFit(targetBounds)","    }","    self.view.addSubview(svgView)","    svgView.bounds = targetBounds","    svgView.center = self.view.center","}"],"type":"codeListing","syntax":"swift"},{"style":"important","type":"aside","name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Both "},{"type":"reference","overridingTitle":"SwiftSVG","identifier":"https:\/\/github.com\/mchoe\/SwiftSVG","isActive":true,"overridingTitleInlineContent":[{"text":"SwiftSVG","type":"text"}]},{"type":"text","text":" and "},{"type":"reference","overridingTitle":"SVG","identifier":"https:\/\/github.com\/SVGKit\/SVGKit","isActive":true,"overridingTitleInlineContent":[{"text":"SVG","type":"text"}]},{"type":"text","text":" only support a subset of SVG features."}]}]},{"level":3,"type":"heading","text":"WebP","anchor":"WebP"},{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"https:\/\/developers.google.com\/speed\/webp","type":"reference"},{"text":" is supported natively on macOS 11+, iOS 14+, and watchOS 7+ via Image I\/O. No additional plugins are required.","type":"text"}]}],"kind":"content"}],"metadata":{"title":"Supported Formats","modules":[{"name":"Nuke"}],"roleHeading":"Article","role":"article"},"seeAlsoSections":[{"identifiers":["doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/PlatformImage","doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/AssetType"],"title":"Supported Images","generated":true,"anchor":"Supported-Images"}],"hierarchy":{"paths":[["doc:\/\/com.github.kean.nuke\/documentation\/Nuke","doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/image-formats"]]},"sections":[],"references":{"doc://com.github.kean.nuke/documentation/Nuke/ImageDecoders/Default":{"type":"topic","role":"symbol","kind":"symbol","title":"ImageDecoders.Default","navigatorTitle":[{"kind":"identifier","text":"Default"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Default"}],"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImageDecoders\/Default","abstract":[{"type":"text","text":"A decoder that supports all of the formats natively supported by the system."}],"url":"\/documentation\/nuke\/imagedecoders\/default"},"doc://com.github.kean.nuke/documentation/Nuke/ImageContainer":{"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImageContainer","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"An image container with an image and associated metadata."}],"role":"symbol","url":"\/documentation\/nuke\/imagecontainer","title":"ImageContainer","navigatorTitle":[{"kind":"identifier","text":"ImageContainer"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ImageContainer"}]},"https://github.com/SVGKit/SVGKit":{"titleInlineContent":[{"text":"SVG","type":"text"}],"title":"SVG","type":"link","url":"https:\/\/github.com\/SVGKit\/SVGKit","identifier":"https:\/\/github.com