raph","inlineContent":[{"text":"Pass an ","type":"text"},{"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImageRequest","isActive":true,"type":"reference"},{"text":" to apply processors or set priority.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["LazyImage(request: ImageRequest(","    url: url,","    processors: [.resize(width: 320)]","))"]},{"type":"aside","style":"tip","name":"Tip","content":[{"inlineContent":[{"text":"Using ","type":"text"},{"code":"processors","type":"codeVoice"},{"text":" ensures the resized image is stored in the memory cache at the display size, reducing memory pressure. See ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/image-processing"},{"text":" to learn more.","type":"text"}],"type":"paragraph"}]},{"type":"heading","text":"Using a Custom Pipeline","anchor":"Using-a-Custom-Pipeline","level":2},{"type":"paragraph","inlineContent":[{"text":"To use a pipeline other than ","type":"text"},{"identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImagePipeline\/shared","isActive":true,"type":"reference"},{"text":", pass it via the environment.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["ContentView()","    .environment(\\.imagePipeline, myPipeline)"]},{"type":"paragraph","inlineContent":[{"text":"All ","type":"text"},{"code":"LazyImage","type":"codeVoice"},{"text":" views in that subtree will use ","type":"text"},{"code":"myPipeline","type":"codeVoice"},{"text":" automatically.","type":"text"}]},{"type":"heading","text":"FetchImage for Custom Views","anchor":"FetchImage-for-Custom-Views","level":2},{"type":"paragraph","inlineContent":[{"code":"FetchImage","type":"codeVoice"},{"text":" is an ","type":"text"},{"code":"ObservableObject","type":"codeVoice"},{"text":" that gives you full control of the loading lifecycle. Use it when you need to drive your own custom view.","type":"text"}]},{"type":"codeListing",