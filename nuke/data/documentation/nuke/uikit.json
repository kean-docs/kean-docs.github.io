{"hierarchy":{"paths":[["doc:\/\/com.github.kean.nuke\/documentation\/Nuke"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/nuke\/uikit"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/uikit","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Load images into UIImageView, NSImageView, and UIButton using the NukeExtensions module."}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/github.com\/kean\/NukeExtensions","isActive":true},{"type":"text","text":" is a companion module that provides free functions for loading images into "},{"type":"codeVoice","code":"UIImageView"},{"type":"text","text":", "},{"type":"codeVoice","code":"NSImageView"},{"type":"text","text":", and "},{"type":"codeVoice","code":"UIButton"},{"type":"text","text":". Add it to your project via Swift Package Manager alongside Nuke."}]},{"type":"heading","level":2,"text":"Loading Images into UIImageView","anchor":"Loading-Images-into-UIImageView"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The most common use case is loading an image into a "},{"type":"codeVoice","code":"UIImageView"},{"type":"text","text":"."}]},{"syntax":"swift","type":"codeListing","code":["import NukeExtensions","","NukeExtensions.loadImage(with: url, into: imageView)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This uses "},{"type":"reference","identifier":"doc:\/\/com.github.kean.nuke\/documentation\/Nuke\/ImagePipeline\/shared","isActive":true},{"type":"text","text":" and handles caching automatically. The previous request for that image view is cancelled when a new one starts — so it’s safe to call from "},{"type":"codeVoice","code":"cellForItemAt"},{"type":"text","text":" without extra bookkeeping."}]},{"type":"headin