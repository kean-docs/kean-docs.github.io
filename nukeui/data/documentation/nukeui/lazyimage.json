{"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"LazyImage","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Content","kind":"genericParameter"},{"text":"> ","kind":"text"},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI4ViewP"}],"platforms":["iOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.github.kean.nukeui\/documentation\/NukeUI\/LazyImage","type":"reference","isActive":true},{"text":" is designed to be similar to the native ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/SwiftUI\/AsyncImage","type":"reference","isActive":true},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"but it uses ","type":"text"},{"identifier":"https:\/\/github.com\/kean\/Nuke","type":"reference","isActive":true},{"text":" for loading images. You","type":"text"},{"text":" ","type":"text"},{"text":"can take advantage of all of its features, such as caching, prefetching,","type":"text"},{"text":" ","type":"text"},{"text":"task coalescing, smart background decompression, request priorities, and more.","type":"text"}]},{"level":2,"text":"Using LazyImage","anchor":"Using-LazyImage","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The view is instantiated with a ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/url","type":"reference","isActive":true},{"text":" or an ","type":"text"},{"identifier":"doc:\/\/com.github.kean.nukeui\/documentation\/NukeUI\/ImageRequest","type":"reference","isActive":true},{"text":".","type":"text"}]},{"syntax":"swift","code":["struct ContainerView: View {","    var body: some View {","        LazyImage(url: URL(string: \"https:\/\/example.com\/image.jpeg\"))","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The view is called “lazy” because it loads the image only when it appears on the screen. And when it disappears, the current request automatically gets canceled. When the view reappears, the download picks up where it left off, thanks to ","type":"text"},{"identifier":"https:\/\/kean.blog\/post\/resumable-downloads","type":"reference","isActive":true},{"text":".","type":"text"}]},{"name":"Tip","style":"tip","type":"aside","content":[{"inlineContent":[{"type":"text","text":"To change the "},{"type":"codeVoice","code":"onDisappear"},{"type":"text","text":" behavior, use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.github.kean.nukeui\/documentation\/NukeUI\/LazyImage\/onDisappear(_:)"},{"type":"text","text":"."}],"type":"paragraph"}]},{"inlineContent":[{"type":"text","text":"Until the image loads, the view displays a standard placeholder that fills the available space, just like "},{"type":"reference","isActive":true,"overridingTitle":"AsyncImage","overridingTitleInlineContent":[{"type":"text","text":"AsyncImage"}],"identifier":"https:\/\/developer.apple.com\/documentation\/SwiftUI\/AsyncImage"},{"type":"text","text":" does. After the load completes successfully, the view updates to display the image."}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"nukeui-preview"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To gain more control over the loading process and how the image is displayed, use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.github.kean.nukeui\/documentation\/NukeUI\/LazyImage\/init(url:transaction:content:)"},{"type":"text","text":", which takes a "},{"type":"codeVoice","code":"content"},{"type":"text","text":" closure that receives a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.github.kean.nukeui\/documentation\/NukeUI\/LazyImageState"},{"type":"text","text":"."}],"type":"paragraph"},{"syntax":"swift","code":["LazyImage(url: URL(string: \"https:\/\/example.com\/image.jpeg\")) { state in","    if let image = state.image {","        image.resizable().aspectRatio(contentMode: .fill)","    } else if state.error != nil {","        Color.red \/\/ Indicates an error","    } else {","        Color.blue \/\/ Acts as a placeholder","    }","}"],"type":"codeListing"},{"name":"Important","style":"important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can’t apply image-specific modifiers, like "},{"type":"codeVoice","code":"resizable(capInsets:resizingMode:)"},{"type":"text","text":", directly to a "},{"type":"codeVoice","code":"LazyImage"},{"type":"text","text":". Instead, apply them to the "},{"type":"codeVoice","code":"Image"},{"type":"text","text":" instance that your content closure gets when defining the view’s appearance."}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the image is loaded, it is displayed with no animation, which is a recommended option. If you add an animation, it’s automatically applied when the image is downloaded, but not when it’s retrieved from the memory cache."}]},{"syntax":"swift","code":["LazyImage(url: URL(string: \"https:\/\/example.com\/image.jpeg\"))","    .animation(.default)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"LazyImage"},{"type":"text","text":" can be instantiated with an "},{"type":"codeVoice","code":"ImageRequest"},{"type":"text","text":" or configured using convenience modifiers."}]},{"type":"codeListing","syntax":"swift","code":["LazyImage(request: ImageRequest(","    url: URL(string: \"https:\/\/example.com\/image.jpeg\"),","    processors: [.resize(width: 44)]","))","","LazyImage(url: URL(string: \"https:\/\/example.com\/image.jpeg\"))","    .processors([.resize(width: 44)])","    .priority(.high)","    .pipeline(customPipeline)"]},{"type":"aside","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"identifier":"doc:\/\/com.github.kean.nukeui\/documentation\/NukeUI\/LazyImage","type":"reference","isActive":true},{"type":"text","text":" is built on top of "},{"type":"reference","identifier":"doc:\/\/com.github.kean.nukeui\/documentation\/NukeUI\/FetchImage","isActive":true},{"type":"text","text":". If you want even more control, you can use it directly instead."}]}],"style":"tip"}]}],"variants":[{"paths":["\/documentation\/nukeui\/lazyimage"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/com.github.kean.nukeui\/documentation\/NukeUI\/LazyImage","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.github.kean.nukeui\/documentation\/NukeUI"]]},"abstract":[{"type":"text","text":"A view that asynchronously loads and displays an image."}],"metadata":{"symbolKind":"struct","modules":[{"name":"NukeUI"}],"title":"LazyImage","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LazyImage","kind":"identifier"}],"roleHeading":"Structure","role":"symbol","externalID":"s:6NukeUI9LazyImageV","navigatorTitle":[{"text":"LazyImage","kind":"identifier"}]},"topicSections":[{"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/com.github.kean.nukeui\/documentation\/NukeUI\/LazyImage\/init(url:)","doc:\/\/com.github.kean.nukeui\/documentation\/NukeUI\/LazyImage\/init(request:)","doc:\/\/com.github.kean.nukeui\/documentation\/NukeUI\/LazyImage\/init(url:transaction:content:)","doc:\/\/com.github.kean.nukeui\/documentation\/NukeUI\/LazyImage\/init(request:transaction:content:)"]},{"title":"Cancellation","anchor":"Cancellation","identifiers":["doc:\/\/com.github.kean.nukeui\/documentation\/NukeUI\/LazyImage\/o